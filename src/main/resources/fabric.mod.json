{
	"schemaVersion": 1,
	"id": "sortmod",
	"version": "${version}",
	"name": "SortMod",
	"description": "Inventory utility companion: quick-stack to nearby chests, persistent frozen slots, hotbar auto-restock, cross-inventory search, and slash commands. Pairs cleanly with ClientSort.",
	"authors": [
		"tom"
	],
	"license": "CC0-1.0",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.tom.sortmod.SortMod"
		],
		"client": [
			"com.tom.sortmod.SortModClient"
		],
		"modmenu": [
			"com.tom.sortmod.modmenu.SortModMenuApi"
		]
	},
	"mixins": [
    "sortmod.mixins.json",
    {
        "config": "modid.client.mixins.json",
        "environment": "client"
    }
],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	},
	"recommends": {
		"modmenu": "*"
	},
	"icon": "assets/modid/icon.png"
}